# Intentionally vulnerable Apache 2.4.49 configuration
# CVE-2021-41773: path traversal via /cgi-bin/..%2f
ServerRoot "/opt/apache-vulnerable"
Listen 80
ServerName vuln-vm.skg.lab

LoadModule authz_core_module modules/mod_authz_core.so
LoadModule mpm_event_module modules/mod_mpm_event.so
LoadModule log_config_module modules/mod_log_config.so
LoadModule dir_module modules/mod_dir.so
LoadModule alias_module modules/mod_alias.so
LoadModule cgi_module modules/mod_cgi.so
LoadModule unixd_module modules/mod_unixd.so

DocumentRoot "/opt/apache-vulnerable/htdocs"

<Directory "/opt/apache-vulnerable/htdocs">
    Options Indexes FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

# CGI enabled — required for CVE-2021-41773 exploitation path
<Directory "/opt/apache-vulnerable/cgi-bin">
    AllowOverride None
    Options +ExecCGI
    Require all granted
</Directory>

ErrorLog "logs/error_log"
CustomLog "logs/access_log" combined
