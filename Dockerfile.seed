FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
RUN npx --yes tsx --version > /dev/null
COPY tsconfig.json ./
COPY src/lib/ ./src/lib/
COPY scripts/seed-neo4j.ts scripts/seed-data.ts ./scripts/
COPY cml/topology.yaml ./cml/
CMD ["npx", "tsx", "scripts/seed-neo4j.ts"]
